!pragma layout smetana
skinparam backgroundColor white
skinparam nodesep 80
skinparam ranksep 80
title MAP-00 - Mappa architettura ACL
skinparam shadowing false
left to right direction

rectangle "Documento sorgente" as Source {
  rectangle "design/DESIGN.md" as DesignDoc
}

rectangle "use case" as UseCase {
  rectangle "00_mappa_use_case.puml" as UC00
  rectangle "01..08 casi d'uso" as UCMore
}

rectangle "componenti" as Componenti {
  rectangle "00_mappa_componenti.puml" as CMP00
  rectangle "01..07 componenti" as CMPMore
}

rectangle "attivita" as Attivita {
  rectangle "00_mappa_attivita.puml" as ACT00
  rectangle "01..10 flussi" as ACTMore
}

rectangle "classi" as Classi {
  rectangle "00_modello_concettuale.puml" as CLS00
  rectangle "01..07 classi" as CLSMore
}

rectangle "oggetti" as Oggetti {
  rectangle "00_mappa_oggetti.puml" as OBJ00
  rectangle "01..10 scenari" as OBJMore
}

DesignDoc --> UC00
DesignDoc --> CMP00
DesignDoc --> ACT00
DesignDoc --> CLS00
DesignDoc --> OBJ00

UC00 --> CMP00
CMP00 --> CLS00
CLS00 --> ACT00
ACT00 --> OBJ00
OBJ00 --> UC00

note bottom
  Ingresso rapido:
  [[use%20case/00_mappa_use_case.puml Use case]] |
  [[componenti/00_mappa_componenti.puml Componenti]] |
  [[attivit%C3%A0/00_mappa_attivita.puml Attivita]] |
  [[classi/00_modello_concettuale.puml Classi]] |
  [[oggetti/00_mappa_oggetti.puml Oggetti]]

  Relazioni:
  DESIGN.md -> use case: attori e casi d'uso
  DESIGN.md -> componenti: layer e porte
  DESIGN.md -> attivita: algoritmi e workflow
  DESIGN.md -> classi: modello e contratti
  DESIGN.md -> oggetti: istanze esemplari
end note
@enduml
