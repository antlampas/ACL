!pragma layout smetana
skinparam backgroundColor white
skinparam nodesep 80
skinparam ranksep 80
title CLS-07 - Errori, audit e DecisionTrace
skinparam shadowing false
hide empty members

class DecisionTrace {
  +subject : SubjectRef
  +profile : Profile
  +operation : OperationName
  +resource : ResourceRef
  +decision : Decision
  +reason : str
  +explicit_deny : bool
  +matched_entry_ids : list[ACLEntryId]
  +visited_resources : list[ResourceRef]
}

abstract class ACLError
class AuthenticationRequired
class AuthorizationDenied
class ACLValidationError
class GrantConstraintError

class AuditEvent <<Enum>> {
  AUTHZ_DENIED
  ACL_ENTRY_CREATED
  ACL_ENTRY_UPDATED
  ACL_ENTRY_DELETED
  PROFILE_CHANGED
  BOOTSTRAP_COMPLETED
}

class AuditRecord {
  +event : AuditEvent
  +actor : SubjectRef?
  +resource : ResourceRef?
  +operation : OperationName?
  +trace : DecisionTrace?
}

ACLError <|-- AuthenticationRequired
ACLError <|-- AuthorizationDenied
ACLError <|-- ACLValidationError
ACLError <|-- GrantConstraintError
AuditRecord --> AuditEvent
AuditRecord --> DecisionTrace

note bottom of DecisionTrace
  La trace e' utile per audit/debug amministrativo.
  Non va esposta a soggetti finali non autorizzati.
end note

legend
  Vedi anche: [[../use%20case/07_spiegare_decisione_audit.puml UC-07]] |
  [[../componenti/07_errori_audit.puml CMP-07]]
endlegend
@enduml
